# ============================================
# Vehicle Video Pipeline - Environment Config
# ============================================
# Copy this to .env and fill in your values

# --- Google / Gemini (multimodal extraction) ---
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- OpenAI / Sora (video generation) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- Dealer Branding ---
# These appear on every video as overlays
DEALER_NAME=San Antonio Dodge Chrysler Jeep Ram
DEALER_PHONE=(210) 555-1234
DEALER_ADDRESS=123 Main St, San Antonio, TX 78201
DEALER_WEBSITE=www.example.com
DEALER_LOGO_PATH=

# --- Pipeline Settings ---
# Video quality: fast, standard, pro
VIDEO_QUALITY=fast

# Max dollar spend per pipeline run
COST_LIMIT=50.00

# Video aspect ratio: 16:9 (landscape) or 9:16 (vertical/social)
VIDEO_ASPECT_RATIO=9:16

# Video resolution: 720p or 1080p
VIDEO_RESOLUTION=720p

# --- Google Cloud Storage (video persistence) ---
# Bucket name for storing generated videos
GCS_BUCKET_NAME=
# Path to service account JSON key file (optional — leave empty to use Application Default Credentials)
GCS_CREDENTIALS_PATH=
# Custom base URL for public video links (optional — leave empty for default GCS URL)
GCS_PUBLIC_URL_BASE=

# --- Overlay Customization ---
# Path to a .ttf font file (leave empty for system default)
OVERLAY_FONT=
# Default call-to-action text
OVERLAY_CTA_TEXT=Call Today!
