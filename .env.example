# ============================================
# CarGurus Video Pipeline - Environment Config
# ============================================
# Copy this to .env and fill in your values

# --- Google / Gemini ---
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# --- OpenAI / Sora ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# --- CarGurus ---
# Your dealer's CarGurus inventory page URL
CARGURUS_DEALER_URL=https://www.cargurus.com/Cars/inventorylisting/viewDetailsFilterViewInventoryListing.action?sourceContext=carGurusHomePageModel&entitySelectingHelper.selectedEntity=d2331

# Dealer name (used in video scripts)
DEALER_NAME=San Antonio Dodge Chrysler Jeep Ram

# --- Pipeline Settings ---
# Max vehicles to process per run (0 = all)
MAX_VEHICLES=0

# Video quality: fast, standard, pro
VIDEO_QUALITY=fast

# Max dollar spend per pipeline run
COST_LIMIT=50.00

# Primary video engine: veo, sora
PRIMARY_VIDEO_ENGINE=veo

# Video aspect ratio: 16:9 (landscape) or 9:16 (vertical/social)
VIDEO_ASPECT_RATIO=9:16

# Video resolution: 720p or 1080p
VIDEO_RESOLUTION=720p
